# Copy this file to .env and replace values for your environment.
# docker-compose automatically reads .env from the project root.

# GCP project used by Airflow Secret Manager backend and pipeline resources
GCP_PROJECT=your-gcp-project-id

# Raw data bucket used by the pipeline
RAW_BUCKET=grocery-raw

# Kaggle credentials for dataset download
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Looker Studio dashboard report ID
LOOKER_STUDIO_REPORT_ID=your-looker-report-id

# Shared JWT secret for Airflow API auth between webserver/scheduler/worker
AIRFLOW_JWT_SECRET=airflow-jwt-secret-dev

# In-container credentials path (host file should exist at ./gcp-key.json)
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/gcp-key.json
